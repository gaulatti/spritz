# Database
DB_HOST=db
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# Secrets Manager (production)
# Keep these as runtime env vars; put app config in the secret JSON.
# APP_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:spritz
# APP_SECRET_KEY=
# AWS_REGION=us-east-1

# WordPress
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_TITLE=ModoItaliano
WP_DEBUG=false

# WordPress salts (production: put these in Secrets Manager)
# AUTH_KEY=
# SECURE_AUTH_KEY=
# LOGGED_IN_KEY=
# NONCE_KEY=
# AUTH_SALT=
# SECURE_AUTH_SALT=
# LOGGED_IN_SALT=
# NONCE_SALT=

# Admin (only used on first boot)
ADMIN_USER=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# Cronkite Pipeline
# CRONKITE_URL=https://api.cronkite.fifthbell.com
# CRONKITE_TENANT_SLUG=modoitaliano
# PIPELINE_TOKEN=

# Default language for posts (en, es, it)
# DEFAULT_LANGUAGE=en

# S3 / CloudFront media
# S3_UPLOADS_BUCKET=
# S3_UPLOADS_PREFIX=uploads
# CLOUDFRONT_MEDIA_DOMAIN=

# Google OAuth (OpenID Connect)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_ALLOWED_DOMAIN=

# NestJS webhook (legacy)
# NESTJS_WEBHOOK_URL=
# NESTJS_WEBHOOK_SECRET=
