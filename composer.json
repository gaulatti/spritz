{
    "name": "spritz/wordpress",
    "description": "Headless WordPress CMS — part of the Cronkite stack",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "johnpbloch/wordpress": "^7.0",
        "composer/installers": "^2.3",
        "wpackagist-plugin/advanced-custom-fields": "^6.3",
        "wpackagist-plugin/amazon-s3-and-cloudfront": "^3.0",
        "wpackagist-plugin/daggerhart-openid-connect-generic": "^3.11",
        "aws/aws-sdk-php": "^3.337"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "extra": {
        "wordpress-install-dir": "wordpress"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "johnpbloch/wordpress-core-installer": true
        }
    }
}
